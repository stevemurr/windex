# Copy to .env and adjust. All settings have WINDEX_ prefix; see src/windex/config.py.

# Storage
WINDEX_DATA_ROOT=/Volumes/External/windex
WINDEX_PG_DSN=postgresql://windex:windex@127.0.0.1:5432/windex
WINDEX_QDRANT_URL=http://127.0.0.1:6333

# Embedding model (bring your own — fill these in once the model is up)
# backend: http-tei | http-openai | st
WINDEX_EMBED_BACKEND=http-tei
WINDEX_EMBED_ENDPOINT=http://127.0.0.1:8080
WINDEX_EMBED_MODEL=placeholder
WINDEX_EMBED_DIM=0
WINDEX_EMBED_MAX_TOKENS=512
WINDEX_EMBED_BATCH_SIZE=64

# Corpus policy
WINDEX_NEWS_BACKFILL_DAYS=90
WINDEX_NEWS_LANGUAGE=en
WINDEX_MINHASH_WINDOW_DAYS=14
WINDEX_REPO_STAR_THRESHOLD=10
# arXiv OAI-PMH harvest (metadata only, CC0). Defaults follow arXiv's ToU;
# WINDEX_ARXIV_REQUEST_INTERVAL must stay >= 3s (1 request / 3 seconds).
WINDEX_ARXIV_INCREMENTAL_DAYS=7
WINDEX_ARXIV_REQUEST_INTERVAL=3.0

# GitHub hydration (comma-separated PATs)
WINDEX_GITHUB_TOKENS=
