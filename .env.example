# Copy to .env and adjust. All settings have WINDEX_ prefix; see src/windex/config.py.

# Storage
WINDEX_DATA_ROOT=/Volumes/External/windex
WINDEX_PG_DSN=postgresql://windex:windex@127.0.0.1:5432/windex
WINDEX_QDRANT_URL=http://127.0.0.1:6333

# Embedding model (bring your own — fill these in once the model is up)
# backend: http-tei | http-openai | st
WINDEX_EMBED_BACKEND=http-tei
WINDEX_EMBED_ENDPOINT=http://127.0.0.1:8080
WINDEX_EMBED_MODEL=placeholder
WINDEX_EMBED_DIM=0
WINDEX_EMBED_MAX_TOKENS=512
WINDEX_EMBED_BATCH_SIZE=64

# Corpus policy
WINDEX_NEWS_BACKFILL_DAYS=90
WINDEX_NEWS_LANGUAGE=en
WINDEX_MINHASH_WINDOW_DAYS=14
WINDEX_REPO_STAR_THRESHOLD=10
# arXiv OAI-PMH harvest (metadata only, CC0). Defaults follow arXiv's ToU;
# WINDEX_ARXIV_REQUEST_INTERVAL must stay >= 3s (1 request / 3 seconds).
WINDEX_ARXIV_INCREMENTAL_DAYS=7
WINDEX_ARXIV_REQUEST_INTERVAL=3.0
# Small Web (Kagi smallweb.txt, MIT). windex's only fetch-based source: a polite
# feed + HTML poller. These knobs are the politeness posture — keep the per-host
# interval and concurrency conservative; keep the User-Agent honest (config.py).
WINDEX_SMALLWEB_MAX_ITEMS=15
WINDEX_SMALLWEB_CONCURRENCY=12
WINDEX_SMALLWEB_HOST_INTERVAL=10.0
WINDEX_SMALLWEB_MAX_FAIL=5

# GitHub hydration (comma-separated PATs)
WINDEX_GITHUB_TOKENS=

# Programming docs (DevDocs pre-built bundles, per-docset upstream licenses).
# WINDEX_DOCS_SLUGS picks which of the ~819 docsets to index. The default (see
# config.py) covers the mainstream stack; whales (openjdk 120MB, dom 63MB,
# cpp 42MB) are excluded — append them per need. Version-pinned slugs
# (python~3.14, postgresql~18, …) should be bumped together with the
# canonical-URL table in src/windex/docs_source/canonical.py.
#WINDEX_DOCS_SLUGS=python~3.14,javascript,typescript,node,go,rust,c,react,vue~3,html,css,http,postgresql~18,git,bash,php,ruby~3.4,django~6.1,flask,tailwindcss,docker,kubernetes

# Hacker News (stories only). Tail + backfill via the Algolia HN Search API
# (free, no auth, ~10k req/hr/IP — keep the pacing polite anyway); fast backfill
# via the open-index/hacker-news parquet mirror (ODC-By 1.0). The incremental
# window trails a couple of days on purpose: the re-pull refreshes story points
# in the payload without re-embedding unchanged text.
WINDEX_HN_INCREMENTAL_DAYS=2
WINDEX_HN_REQUEST_INTERVAL=0.4

# Hugging Face (huggingface.co docs, courses, blog — ~4,000 pages; NOT the 3.9M
# model/dataset/Space pages, see docs/huggingface-source.md). windex's second
# fetch-based source and the first pointed at ONE host, so none of the
# SMALLWEB_* knobs above apply: concurrency would be inert behind a single
# host's limiter, and a 10s interval would cost 11 hours. 3.0s is HF's OWN
# number — its `pages` rate-limit bucket is 100 requests / 300s, published on
# every response — and the crawler self-throttles off that live header, so
# lowering this does not make it faster, it just makes it rude.
# WINDEX_HF_ROOTS picks which doc roots to index; EMPTY = all 52 (only ~3,175
# pages, so there is no reason to be selective).
WINDEX_HF_REQUEST_INTERVAL=3.0
#WINDEX_HF_ROOTS=docs/transformers,docs/diffusers,learn/agents-course
